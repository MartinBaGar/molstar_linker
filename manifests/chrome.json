{
  "manifest_version": 3,
  "name": "Mol* Linker",
  "version": "2.1.0",
  "description": "Instantly view PDB and mmCIF files directly from GitHub and GitLab using MolViewSpec and Mol*.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "contextMenus"
  ],
  "host_permissions": [
    "*://*.github.com/*",
    "*://raw.githubusercontent.com/*",
    "*://*.gitlab.com/*",
    "*://*.rcsb.org/*",
    "*://*.alphafold.ebi.ac.uk/*"
  ],
  "optional_host_permissions": [
    "*://*/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Mol* Linker Quick Settings"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js"
  },
  "sandbox": {
    "pages": [
      "sandbox.html"
    ]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none';",
    "sandbox": "sandbox allow-scripts allow-forms allow-popups allow-modals; script-src 'self' 'unsafe-inline' 'unsafe-eval'; child-src 'self';"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.github.com/*",
        "*://*.gitlab.com/*",
        "*://*.rcsb.org/*",
        "*://*.alphafold.ebi.ac.uk/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ]
}